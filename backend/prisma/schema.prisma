generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  prenom    String
  role      String   @default("employé")
  shops     Shop[]   @relation("UserShops")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id        String     @id @default(cuid())
  nom       String
  adresse   String     @default("")
  telephone String     @default("")
  createdBy String
  users     User[]     @relation("UserShops")
  repairs   Repair[]
  stocks    Stock[]
  settings  Settings?
  savs      SAV[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Repair {
  id                        String    @id @default(cuid())
  shopId                    String
  shop                      Shop      @relation(fields: [shopId], references: [id])
  numeroReparation          String    @unique
  type_reparation           String
  client_nom                String
  client_telephone          String
  appareil_marque_modele    String
  pannes_services           Json
  pieces_rechange_utilisees Json
  total_reparation          Float
  montant_paye              Float
  reste_a_payer             Float
  statut_reparation         String
  date_creation             DateTime  @default(now())
  date_mise_en_reparation   DateTime?
  date_rendez_vous          DateTime?
  date_retrait              DateTime?
  etat_paiement             String
  userId                    String
  savs                      SAV[]

  @@index([shopId, date_creation(sort: Desc)])
}

model Stock {
  id                 String @id @default(cuid())
  shopId             String
  shop               Shop   @relation(fields: [shopId], references: [id])
  nom                String
  quantite           Int
  prixAchat          Float
  prixVente          Float
  beneficeNetAttendu Float  @default(0)

  @@index([shopId])
}

model Settings {
  id          String   @id @default(cuid())
  shopId      String   @unique
  shop        Shop     @relation(fields: [shopId], references: [id])
  companyInfo Json
  warranty    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SAV {
  id                      String    @id @default(cuid())
  shopId                  String
  shop                    Shop      @relation(fields: [shopId], references: [id])
  numeroSAV               String    @unique
  repairId                String?
  repair                  Repair?   @relation(fields: [repairId], references: [id])
  numeroReparationOrigine String    @default("")
  client_nom              String
  client_telephone        String
  appareil_marque_modele  String
  description_probleme    String    @db.Text
  sous_garantie           Boolean   @default(false)
  date_fin_garantie       DateTime?
  statut                  String    @default("En attente")
  decision                String    @default("") @db.Text
  date_creation           DateTime  @default(now())
  date_resolution         DateTime?
  notes                   String    @default("") @db.Text
  userId                  String

  @@index([shopId, date_creation(sort: Desc)])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  @@index([expiresAt])
}
