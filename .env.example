APP_NAME="MOMO TECH SERVICE"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://momotechservice.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=momotech
DB_USERNAME=
DB_PASSWORD=

JWT_SECRET=
JWT_TTL=60

SANCTUM_EXPIRATION=60

SESSION_DRIVER=file
SESSION_LIFETIME=60
SESSION_SECURE_COOKIE=true
CACHE_STORE=file

MAIL_MAILER=smtp

